// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  name          String?  @db.VarChar(255)
  role          String   @default("user") @db.VarChar(50)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @db.Timestamp(6)
  links         Link[]

  @@map("users")
}

model Link {
  id             String   @id @default(uuid()) @db.Uuid
  user_id        String   @db.Uuid
  original_url   String   @db.Text
  slug           String   @unique @db.VarChar(255)
  title          String?  @db.VarChar(255)
  password_hash  String?  @db.VarChar(255)
  expires_at     DateTime? @db.Timestamp(6)
  is_active      Boolean  @default(true)
  click_count    Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @default(now()) @db.Timestamp(6)
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  clicks         Click[]

  @@map("links")
}

model Click {
  id               String   @id @default(uuid()) @db.Uuid
  link_id          String   @db.Uuid
  ip_address       String?  @db.VarChar(45)
  user_agent       String?  @db.Text
  browser          String?  @db.VarChar(100)
  browser_version  String?  @db.VarChar(50)
  os               String?  @db.VarChar(100)
  os_version       String?  @db.VarChar(50)
  device           String?  @db.VarChar(50)
  device_type      String?  @db.VarChar(50)
  country          String?  @db.VarChar(100)
  city             String?  @db.VarChar(100)
  referer          String?  @db.Text
  clicked_at       DateTime @default(now()) @db.Timestamp(6)
  link             Link     @relation(fields: [link_id], references: [id], onDelete: Cascade)

  @@map("clicks")
}

model AppSetting {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique @db.VarChar(255)
  value      String   @db.Text
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@map("app_settings")
}